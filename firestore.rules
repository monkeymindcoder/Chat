rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'lastActive']) &&
             data.keys().size() <= 6 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.lastActive == request.time;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['participants', 'updatedAt']) &&
             data.participants is list && 
             data.participants.size() >= 1 && data.participants.size() <= 2 &&
             request.auth.uid in data.participants &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'userName', 'createdAt', 'type']) &&
             data.text is string && data.text.size() <= 5000 &&
             ((data.type == 'user' && data.userId == request.auth.uid) || (data.type == 'ai' && data.userId == 'gemini-ai')) &&
             data.createdAt == request.time &&
             data.type in ['user', 'ai'];
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastActive']);
    }

    // Global Messages Collection
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.token.email_verified == true && isValidMessage(incoming());
      allow delete: if isSignedIn() && request.auth.token.email_verified == true && 
                    (resource.data.userId == request.auth.uid || resource.data.get('type', '') == 'ai');
      allow update: if false; 
    }
  }
}
